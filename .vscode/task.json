{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C++20 Project",
      "type": "shell",
      "command": "g++",
      "args": [
        "-I../DeviceDomain/include",
        "-Iinclude",
        "-I/usr/include",
        "-I/usr/local/include",
        "-std=c++20",
        "-Wall",
        "-Wextra",
        "-Wpedantic",
        "${workspaceFolder}/Src/*.cpp",
        "-o",
        "${workspaceFolder}/../bin/program",
        "-lpthread",
        "-lwiringPi"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}